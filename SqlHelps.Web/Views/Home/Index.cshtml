@model SqlHelps.Web.Models.InquiryViewModel
@{
    ViewData["Title"] = "Modern Database Consulting";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h6 class="text-uppercase mb-3 fw-bold" style="color: var(--accent-cyan); letter-spacing: 4px;">Database Experts</h6>
                <h1 class="display-1 fw-bold mb-4" style="line-height: 1.1;">Empowering Businesses <br>Through <span style="color: var(--accent-blue)">Data Excellence</span></h1>
                <p class="lead mb-5 fs-4" style="color: var(--text-main); max-width: 800px;">SQLHelps provides world-class database consulting, administration, and modernization services to ensure your data is secure, scalable, and high-performing.</p>
                <div class="d-flex gap-3">
                    <a href="#contact" class="btn btn-primary btn-lg">Consult Our Experts</a>
                    <a href="#services" class="btn btn-outline-light btn-lg px-4" style="border-width: 2px;">Our Services</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="py-5 mt-5">
    <div class="container py-5">
        <div class="row mb-5">
            <div class="col-lg-6">
                <h2 class="display-5 fw-bold mb-3">Core Expertise</h2>
                <p class="text-muted">We provide end-to-end database solutions across diverse platforms and cloud environments.</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body service-card">
                        <div class="service-icon"><i class="bi bi-database-fill-gear"></i></div>
                        <h4 class="card-title mb-3">SQL Server</h4>
                        <p class="card-text text-muted">Comprehensive SQL Server management, from installation and configuration to complex performance tuning and health checks.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body service-card">
                        <div class="service-icon"><i class="bi bi-cloud-arrow-up-fill"></i></div>
                        <h4 class="card-title mb-3">Cloud Migration</h4>
                        <p class="card-text text-muted">Seamlessly migrate your on-premise databases to Azure, AWS, or Google Cloud with zero data loss and minimal downtime.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body service-card">
                        <div class="service-icon"><i class="bi bi-shield-lock-fill"></i></div>
                        <h4 class="card-title mb-3">Security & Compliance</h4>
                        <p class="card-text text-muted">Implementing robust security architectures, encryption, and compliance audits to protect your most valuable assets.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body service-card">
                        <div class="service-icon"><i class="bi bi-lightning-charge-fill"></i></div>
                        <h4 class="card-title mb-3">Performance Tuning</h4>
                        <p class="card-text text-muted">Identify bottlenecks and optimize queries, indexing, and resource allocation for lightning-fast database performance.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body service-card">
                        <div class="service-icon"><i class="bi bi-mortarboard-fill"></i></div>
                        <h4 class="card-title mb-3">MCT Training</h4>
                        <p class="card-text text-muted">Specialized training programs for database professionals, led by Microsoft Certified Trainers with real-world experience.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body service-card">
                        <div class="service-icon"><i class="bi bi-infinity"></i></div>
                        <h4 class="card-title mb-3">Remote DBA</h4>
                        <p class="card-text text-muted">24/7 proactive monitoring and administration to ensure your databases remain healthy and highly available.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
<section id="about" class="py-5 bg-light">
    <div class="container py-5">
        <div id="contact" class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <h2 class="display-5 fw-bold mb-4">Why Global Leaders Trust SQLHelps</h2>
                <div class="d-flex mb-4">
                    <div class="me-4 text-primary fs-2"><i class="bi bi-check-circle-fill"></i></div>
                    <div>
                        <h5>Certified Experts</h5>
                        <p class="text-muted">Our team consists of veteran DBAs and Microsoft Certified Trainers with decades of collective experience.</p>
                    </div>
                </div>
                <div class="d-flex mb-4">
                    <div class="me-4 text-primary fs-2"><i class="bi bi-check-circle-fill"></i></div>
                    <div>
                        <h5>Platform Agnostic</h5>
                        <p class="text-muted">Whether it's SQL Server, Oracle, PostgreSQL, or NoSQL, we have the expertise to manage it.</p>
                    </div>
                </div>
                <div class="d-flex">
                    <div class="me-4 text-primary fs-2"><i class="bi bi-check-circle-fill"></i></div>
                    <div>
                        <h5>Result Driven</h5>
                        <p class="text-muted">We focus on measurable outcomes—faster queries, higher availability, and reduced infrastructure costs.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <div class="p-5 rounded-4 shadow-lg bg-white">
                    <h3 class="fw-bold mb-4 text-center">Inquiry Form</h3>
                    
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <form asp-controller="Home" asp-action="SubmitInquiry" method="post">
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control p-3" placeholder="John Doe">
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control p-3" placeholder="john@company.com">
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Message" class="form-label"></label>
                            <textarea asp-for="Message" class="form-control p-3" rows="4" placeholder="How can we help?"></textarea>
                            <span asp-validation-for="Message" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 p-3 fw-bold">Submit Request</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

